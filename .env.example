# Backend Deployment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/presently?sslmode=require

# Your verified email address in AWS SES for sending invitations
SENDER_EMAIL=your-email@example.com

# Frontend URL for invitation links (e.g., your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app
