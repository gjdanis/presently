# =============================================================================
# Presently - Local Development Environment (EXAMPLE)
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# DO NOT commit .env.local to git (it's in .gitignore)

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------

# Database - Use Neon Postgres for AWS dev environment
# Or use local Postgres: postgresql://presently:presently_local@localhost:5433/presently_local
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# AWS S3 for photo storage
PHOTOS_BUCKET=presently-photos-dev-us-east-1-123456789012
AWS_REGION=us-east-1

# Email configuration (must be verified in AWS SES)
SENDER_EMAIL=your-email@example.com

# Environment marker (dev or local)
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Frontend Configuration (NEXT_PUBLIC_ vars are exposed to browser)
# -----------------------------------------------------------------------------

# API URL - use http://localhost:8000 for local backend, or AWS API Gateway URL for dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# AWS Cognito - get these from AWS Console or CloudFormation outputs
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_REGION=us-east-1

# CloudFront CDN (optional - leave empty if not using)
NEXT_PUBLIC_CDN_URL=

# Frontend URL (for invitation links)
FRONTEND_URL=http://localhost:3000

# GitHub (for feedback feature)
# Create a fine-grained PAT at: https://github.com/settings/tokens
# Required permission: Issues (read & write), scoped to this repo
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=your-username/presently

# Buy Me a Coffee (optional — button hidden if not set)
NEXT_PUBLIC_BMC_URL=https://buymeacoffee.com/yourname
