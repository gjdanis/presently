# Local Development Environment Variables
# Copy this file to .env.local and update with your local values
# DO NOT commit .env.local to git

# Local Database (matches docker-compose.local.yml)
DATABASE_URL=postgresql://presently:presently_local@localhost:5433/presently_local

# Local S3/Photo Storage (optional - can use AWS or leave empty for local dev)
PHOTOS_BUCKET=
PHOTOS_CDN=

# Cognito (optional - can mock for local dev or use real AWS Cognito)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Email (optional for local dev)
SENDER_EMAIL=noreply@localhost
FRONTEND_URL=http://localhost:3000

# Environment marker
ENVIRONMENT=local
